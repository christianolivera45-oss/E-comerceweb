rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        (isEmailVerified() && request.auth.token.email == 'justiciaotec@gmail.com') ||
        (request.auth.token.email == 'juem@olivera45.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Settings Collection Rules
    match /settings/{settingsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidSettings(incoming());
    }

    function isValidSettings(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.whatsappNumber is string && data.whatsappNumber.size() <= 32
        && data.themeColor is string && data.themeColor.size() <= 10
        && data.heroTitle is string && data.heroTitle.size() <= 200
        && data.heroSubtitle is string && data.heroSubtitle.size() <= 1000
        && data.heroBannerUrl is string && data.heroBannerUrl.size() <= 2000
        && data.promoBannerText is string && data.promoBannerText.size() <= 1000;
    }

    // Products Collection Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(productId);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 10000
        && data.price is number && data.price >= 0
        && (data.originalPrice == null || (data.originalPrice is number && data.originalPrice >= 0))
        && data.stock is number && data.stock >= 0
        && data.featured is bool
        && data.categories is list && data.categories.size() <= 10
        && data.images is list && data.images.size() <= 10;
    }

    // Categories Collection Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 2000));
    }

    // Promotions Collection Rules
    match /promotions/{promoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(promoId) && isValidPromo(incoming());
      allow delete: if isAdmin() && isValidId(promoId);
    }

    function isValidPromo(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.code is string && data.code.size() > 0 && data.code.size() <= 50
        && data.discountPercent is number && data.discountPercent >= 0 && data.discountPercent <= 100
        && data.active is bool;
    }

    // Admins Collection Rules
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming());
    }

    function isValidAdmin(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.role is string && (data.role == 'superadmin' || data.role == 'editor');
    }
  }
}
